{
    "name": "@anti-matter-studios/tools",
    "version": "0.1.0-alpha.1",
    "files": [
        "dist/src",
        "dist/*.cjs.js",
        "dist/*.esm.js",
        "README.md",
        "LICENCE.md",
        "CHANGELOG.md",
        "package.json"
    ],
    "devDependencies": {
        "@types/triple-beam": "^1.3.5",
        "winston-transport": "^4.7.1"
    },
    "dependencies": {
        "winston": "^3.13.1",
        "triple-beam": "^1.4.1",
        "chalk": "^5.3.0"
    },
    "exports": {
        "./env": {
            "types": "./src/lib/env.d.ts",
            "require": "./env.cjs.js",
            "default": "./env.esm.js"
        },
        "./logger": {
            "types": "./src/lib/logger.d.ts",
            "require": "./logger.cjs.js",
            "default": "./logger.esm.js"
        }
    }
}
